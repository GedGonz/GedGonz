# URL del Gist (site.json). El front usa la API de GitHub (sin caché CDN de 5 min).
# Ejemplo:
# REACT_APP_CONTENT_URL=https://gist.githubusercontent.com/GedGonz/74b343917a8cb29cb1cc35d5d3056c16/raw/site.json
REACT_APP_CONTENT_URL=

# Código del sitio en GoatCounter (https://www.goatcounter.com).
# Si creas el sitio como "gedgonz", el dashboard es https://gedgonz.goatcounter.com
REACT_APP_GOATCOUNTER_CODE=gedgonz
